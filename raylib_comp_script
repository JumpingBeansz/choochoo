SET COMPILER_PATH=C:\raylib\w64devkit\bin
SET PATH=%COMPILER_PATH%;%PATH%

SET CC=gcc
SET CFLAGS=%RAYLIB_PATH%\src\raylib.rc.data -s -static -O3 -std=c99 -Wall -I%RAYLIB_PATH%\src -DPLATFORM_DESKTOP
